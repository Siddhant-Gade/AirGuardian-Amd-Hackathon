# ============================================================
# AirGuardian AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Groq LLM (free at console.groq.com — 2 min signup) ----
GROQ_API_KEY=your_groq_api_key_here

# --- Gmail SMTP Notifications (100% FREE, no paid API) ------
#  Setup (one-time):
#    1. Enable 2-Step Verification on your Google account.
#    2. Visit: myaccount.google.com → Security → App Passwords
#    3. Create a new App Password for "Mail".
#    4. Paste the 16-character code into GMAIL_APP_PASSWORD.
#
GMAIL_SENDER=airguardian@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ALERT_EMAIL=campus_admin@example.com
# Optional: comma-separated CC recipients (leave empty to skip)
ALERT_EMAIL_CC=

# --- Optional: OpenAQ fallback (no key needed for basic use) -
OPENAQ_API_KEY=

# --- App settings -------------------------------------------
DEBUG=False
DB_PATH=airguardian.db
LOG_LEVEL=INFO
